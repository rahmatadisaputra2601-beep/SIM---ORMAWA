{
    "version": 2,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1",
            "memory": 1024,
            "maxDuration": 20
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}